{
  "name": "team-workspace-server",
  "version": "1.0.0",
  "description": "Team Workspace — REST API + Socket.io server",
  "main": "server.js",
  "scripts": {
    "start":         "node server.js",
    "dev":           "nodemon server.js",
    "test":          "NODE_ENV=test jest --runInBand --forceExit",
    "test:watch":    "NODE_ENV=test jest --watch --runInBand",
    "test:coverage": "NODE_ENV=test jest --coverage --runInBand --forceExit",
    "seed":          "node scripts/seed.js",
    "lint":          "eslint src --ext .js"
  },
  "dependencies": {
    "bcryptjs":                "^2.4.3",
    "bullmq":                  "^5.7.0",
    "compression":             "^1.7.4",
    "cookie-parser":           "^1.4.6",
    "cors":                    "^2.8.5",
    "dotenv":                  "^16.4.5",
    "express":                 "^4.19.2",
    "express-mongo-sanitize":  "^2.2.0",
    "express-rate-limit":      "^7.3.1",
    "helmet":                  "^7.1.0",
    "hpp":                     "^0.2.3",
    "ioredis":                 "^5.3.2",
    "joi":                     "^17.13.1",
    "jsonwebtoken":            "^9.0.2",
    "mongoose":                "^8.4.0",
    "morgan":                  "^1.10.0",
    "nodemailer":              "^6.9.13",
    "nodemailer-express-handlebars": "^4.0.0",
    "handlebars":              "^4.7.8",
    "socket.io":               "^4.7.5",
    "winston":                 "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "jest":                    "^29.7.0",
    "mongodb-memory-server":   "^10.0.0",
    "nodemon":                 "^3.1.3",
    "supertest":               "^7.0.0"
  },
  "jest": {
    "testEnvironment":  "node",
    "setupFiles":       ["./tests/setup.js"],
    "testMatch":        ["**/tests/modules/**/*.test.js"],
    "testTimeout":      30000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/jobs/**",
      "!src/modules/email/templates/**"
    ],
    "coverageDirectory": "coverage"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
