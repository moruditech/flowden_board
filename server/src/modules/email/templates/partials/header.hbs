<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="format-detection" content="telephone=no,date=no,address=no,email=no">
  <title>{{subject}}</title>
  <style type="text/css">
    body,html{margin:0;padding:0;background:#f4f4f5;-webkit-font-smoothing:antialiased;}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;}
    table{border-collapse:collapse;mso-table-lspace:0;mso-table-rspace:0;}
    img{border:0;height:auto;line-height:100%;outline:none;text-decoration:none;-ms-interpolation-mode:bicubic;}
    a{color:#4f46e5;}
    .wrapper{width:100%;background:#f4f4f5;padding:40px 16px;box-sizing:border-box;}
    .container{max-width:600px;margin:0 auto;background:#ffffff;border-radius:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);}
    .email-header{background:#4f46e5;padding:28px 40px;text-align:center;}
    .email-logo{font-size:20px;font-weight:700;color:#ffffff;text-decoration:none;letter-spacing:-.5px;}
    .email-logo span{opacity:.7;}
    .email-body{padding:40px;}
    .email-footer{background:#f9fafb;border-top:1px solid #e5e7eb;padding:24px 40px;}
    h1{font-size:24px;font-weight:700;color:#111827;margin:0 0 12px;line-height:1.3;}
    h2{font-size:18px;font-weight:600;color:#111827;margin:24px 0 8px;}
    p{font-size:15px;line-height:1.7;color:#374151;margin:0 0 16px;}
    p.small{font-size:13px;color:#6b7280;line-height:1.6;}
    p.muted{font-size:13px;color:#9ca3af;line-height:1.6;margin:0;}
    hr{border:none;border-top:1px solid #e5e7eb;margin:28px 0;}
    .btn{display:inline-block;padding:13px 28px;background:#4f46e5;color:#ffffff!important;text-decoration:none;border-radius:7px;font-weight:600;font-size:15px;line-height:1;mso-padding-alt:0;}
    .btn-outline{display:inline-block;padding:11px 24px;background:transparent;color:#4f46e5!important;text-decoration:none;border-radius:7px;font-weight:600;font-size:14px;border:2px solid #4f46e5;}
    .card{background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:20px 24px;margin:16px 0;}
    .card p{margin:4px 0;font-size:14px;color:#374151;}
    .card p strong{color:#111827;}
    .badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;}
    .badge-admin{background:#ede9fe;color:#5b21b6;}
    .badge-member{background:#e0f2fe;color:#0369a1;}
    .badge-owner{background:#fef3c7;color:#92400e;}
    .tag{display:inline-block;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:500;background:#e5e7eb;color:#374151;}
    .alert{border-left:4px solid #f59e0b;background:#fffbeb;padding:14px 18px;border-radius:0 6px 6px 0;margin:16px 0;}
    .alert p{margin:0;font-size:14px;color:#92400e;}
    @media only screen and (max-width:600px){
      .wrapper{padding:20px 8px!important;}
      .email-body{padding:24px 20px!important;}
      .email-footer{padding:20px!important;}
    }
    @media (prefers-color-scheme:dark){
      .container{background:#1f2937!important;}
      .email-body{background:#1f2937!important;}
      h1,h2{color:#f9fafb!important;}
      p{color:#d1d5db!important;}
      .card{background:#374151!important;border-color:#4b5563!important;}
      .card p{color:#d1d5db!important;}
      .card p strong{color:#f9fafb!important;}
    }
  </style>
</head>
<body>
<div class="wrapper">
<table class="container" cellpadding="0" cellspacing="0" role="presentation" width="100%">
  <tr><td class="email-header">
    <a href="{{appUrl}}" class="email-logo">&#11041; Team<span>Workspace</span></a>
  </td></tr>
  <tr><td class="email-body">
